{
  "name": "@eduriam/ui-core",
  "version": "0.6.65",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo || rmdir /s /q dist && del /q tsconfig.tsbuildinfo 2>nul",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "mermaid": "^11.12.0"
  },
  "peerDependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/material": "^5",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^5.15.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eduriam/EduriamUI.git",
    "directory": "src/eduriam-ui-core"
  }
}
