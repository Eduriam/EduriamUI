{
  "name": "eduriam-ui",
  "private": true,
  "packageManager": "yarn@4.5.1",
  "workspaces": [
    "src/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs",
    "prettier": "prettier --write .",
    "build": "yarn workspace @eduriam/ui-core build && yarn workspace @eduriam/ui-x build",
    "clean": "yarn workspace @eduriam/ui-core clean && yarn workspace @eduriam/ui-x clean",
    "typecheck": "yarn workspace @eduriam/ui-core typecheck && yarn workspace @eduriam/ui-x typecheck && tsc -p tsconfig.api-parity.json",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "build-storybook": "storybook build",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "4.1.1",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^5.15.20",
    "@storybook/addon-a11y": "9.1.10",
    "@storybook/addon-docs": "9.1.10",
    "@storybook/addon-vitest": "9.1.10",
    "@storybook/react-vite": "^9.1.10",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-storybook": "^9.1.13",
    "husky": "^9.1.7",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "regenerator-runtime": "^0.13.11",
    "storybook": "^9.1.10",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vite": "^5.4.9",
    "vitest": "^3.2.4"
  }
}
